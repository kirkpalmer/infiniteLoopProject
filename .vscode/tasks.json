{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install strategy-lab dependencies",
			"type": "shell",
			"command": "pip",
			"args": [
				"install",
				"-r",
				"strategy-lab/requirements.txt",
				"--break-system-packages"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "Refresh strategy-lab dependencies",
			"type": "shell",
			"command": "pip",
			"args": [
				"install",
				"-r",
				"strategy-lab/requirements.txt",
				"--break-system-packages"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		}
	]
}